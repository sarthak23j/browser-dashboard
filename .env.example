# Copy this file to .env and adjust values as needed

# Path to the SQLite database file (relative to the backend/ directory)
DATABASE_URL=sqlite:///./dashboard.db

# Directory containing the built frontend (relative to project root)
STATIC_DIR=../dist

# The port the backend will run on
PORT=8000
# For the Vite dev server proxy to know which port to proxy requests to
VITE_BACKEND_PORT=8000
